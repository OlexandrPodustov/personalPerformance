{
  "rust-analyzer.linkedProjects": [
    "Cargo.toml"
  ],
  "rust-analyzer.files.exclude": [
    "rust/exercises"
  ],
  "emeraldwalk.runonsave": {
    "autoClearConsole": true,
    "commands": [
      {
        "match": "\\.rs$",
        "cmd": "cd \"${fileDirname}\" && cargo test"
      }
    ]
  }
}